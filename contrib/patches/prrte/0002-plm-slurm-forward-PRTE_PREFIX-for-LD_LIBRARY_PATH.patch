+        if (NULL == prefix && NULL != saved_prte_prefix) {
+            /* Reset PATH */
+            oldenv = getenv("PATH");
+            if (NULL != oldenv) {
+                pmix_asprintf(&newenv, "%s/%s:%s", saved_prte_prefix, bin_base, oldenv);
